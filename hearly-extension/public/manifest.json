{
  "name": "Hearly",
  "version": "1.0.0",
  "description": "AI-powered voice focus tool for meetings",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": [
        "content-meet.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://zoom.us/*",
        "https://app.zoom.us/*"
      ],
      "js": [
        "content-zoom.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": [
        "content-teams.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "tabCapture",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://zoom.us/*",
    "https://app.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*"
  ]
}
